		"_postman_id": "ytu-api-collection-2024",
		"name": "Y TU API - Complete Collection",
		"description": "Comprehensive Postman collection for Y TU API - AI Translation and Human Tone Authentication API\n\n## Features\n- Translation services\n- Tone analysis\n- AI response generation\n- Full processing pipeline\n- API key management\n- Usage metrics\n\n## Setup\n1. Import this collection\n2. Create an environment with:\n   - `api_url`: Your API base URL (e.g., http://localhost:3000)\n   - `api_key`: Your API key\n3. Select the environment\n4. Start testing!\n\n## Rate Limits\n- FREE: 100 requests/day\n- STARTER: 1,000 requests/day\n- PRO: 10,000 requests/day\n- ENTERPRISE: Unlimited",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
