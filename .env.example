# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development
API_VERSION=v1
BASE_URL=http://localhost:3000

# ============================================
# Rate Limiting Configuration
# ============================================
# Standard rate limit: requests per window
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Throttle limit: requests per second
THROTTLE_WINDOW_MS=1000
THROTTLE_MAX_REQUESTS=50

# Custom rate limit message
RATE_LIMIT_MESSAGE=Too many requests from this IP, please try again later.

# ============================================
# CORS Configuration
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# ============================================
# Database Configuration
# ============================================
# Option 1: Full connection string (recommended)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name
# or
# DATABASE_CONNECTION_STRING=postgresql://username:password@localhost:5432/database_name

# Option 2: Individual database settings
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=ytu_db
# DATABASE_USERNAME=your_username
# DATABASE_PASSWORD=your_password
# DATABASE_SSL=false

# ============================================
# AI Service API Keys
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
TRANSLATION_SERVICE_API_KEY=your_translation_service_api_key_here
TRANSLATION_SERVICE_URL=https://api.translation-service.com

# ============================================
# JWT Authentication Configuration
# ============================================
# IMPORTANT: Change this to a secure random string in production (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=ytu-api
JWT_AUDIENCE=ytu-api-users

# ============================================
# Vercel Deployment (optional)
# ============================================
VERCEL_URL=your_vercel_url_here
